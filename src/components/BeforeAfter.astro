---
const baseUrl = import.meta.env.BASE_URL;

// Menggunakan data gambar sementara, silakan ganti nama file sesuai dengan gambar asli jika ada
const categories = [
  { id: 'deep-cleaning', label: 'DEEP CLEANING', before: `${baseUrl}images/before-dirty.png`, after: `${baseUrl}images/after-clean.png` },
  { id: 'whitening', label: 'WHITENING', before: `${baseUrl}images/before-dirty.png`, after: `${baseUrl}images/after-clean.png` },
  { id: 'repaint', label: 'REPAINT', before: `${baseUrl}images/before-dirty.png`, after: `${baseUrl}images/after-clean.png` },
  { id: 'unyellowing', label: 'UNYELLOWING', before: `${baseUrl}images/before-dirty.png`, after: `${baseUrl}images/after-clean.png` }
];
---

<section id="hasil" class="py-24 md:py-32 bg-[#0A0A0A] relative z-20">
  <div class="container-main max-w-6xl mx-auto px-4">
    
    <!-- Header -->
    <div class="text-left mb-16 md:mb-20">
      <span class="inline-block text-[#FFE600] font-bold text-sm sm:text-base tracking-[0.25em] uppercase mb-5">
        BUKTI NYATA
      </span>
      <h2 class="font-display text-[4rem] sm:text-[5rem] lg:text-[7rem] leading-[0.9] uppercase tracking-wide mb-6">
        <span class="block text-white">HASILNYA</span>
        <span class="block text-[#FFE600]">BICARA SENDIRI</span>
      </h2>
      <p class="text-[#A1A1A1] text-lg sm:text-xl max-w-xl">
        Geser untuk melihat perubahan nyata.
      </p>
    </div>

    <!-- Service Tabs -->
    <div class="flex overflow-x-auto flex-nowrap md:flex-wrap md:justify-center gap-2 sm:gap-4 mb-12 lg:mb-16 pb-2 px-2 sm:px-0 no-scrollbar snap-x">
      {categories.map((cat, index) => (
        <button
          class={`ba-tab flex-shrink-0 whitespace-nowrap snap-start px-4 sm:px-8 py-2.5 sm:py-3 rounded-full text-[10px] sm:text-sm tracking-[0.1em] uppercase font-bold transition-all duration-300 border 
          ${index === 0 
            ? 'bg-[#FFE600] text-black border-[#FFE600]' 
            : 'bg-transparent text-[#A1A1A1] border-white/20 hover:border-[#FFE600]'
          }`}
          data-index={index}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Before After Slider Portfolio -->
    <div class="max-w-5xl mx-auto">
      <div 
        id="ba-container"
        class="relative rounded-[20px] overflow-hidden border border-white/10 shadow-[0_20px_60px_rgba(0,0,0,0.6)] aspect-square sm:aspect-[4/3] lg:aspect-[16/9] bg-[#111111]"
      >
        <!-- Loading State Overlay -->
        <div id="ba-loader" class="absolute inset-0 z-30 bg-[#111111]/80 backdrop-blur-sm flex items-center justify-center transition-opacity duration-300 opacity-0 pointer-events-none">
           <div class="w-12 h-12 border-4 border-white/10 border-t-[#FFE600] rounded-full animate-spin"></div>
        </div>

        <!-- BASE LAYER: After Image -->
        <div class="absolute inset-0 bg-[#111111]">
          <img
            id="img-after"
            src={categories[0].after}
            alt="Sesudah"
            class="w-full h-full object-cover transition-opacity duration-300"
            loading="lazy"
          />
        </div>

        <!-- TOP LAYER (CLIPPED): Before Image -->
        <div class="absolute inset-0 z-10 transition-opacity duration-300" id="ba-before" style="clip-path: inset(0 50% 0 0);">
          <img
            id="img-before"
            src={categories[0].before}
            alt="Sebelum"
            class="w-full h-full object-cover bg-[#111111]"
            loading="lazy"
          />
        </div>

        <!-- ALWAYS VISIBLE BADGES -->
        <!-- Badge SEBELUM -->
        <div class="absolute top-6 left-6 z-20 bg-[#0A0A0A]/80 backdrop-blur-md text-white text-xs sm:text-sm font-bold tracking-[0.15em] uppercase px-5 py-2.5 rounded-full border border-white/10 shadow-lg pointer-events-none">
          SEBELUM
        </div>
        <!-- Badge SESUDAH -->
        <div class="absolute top-6 right-6 z-20 bg-[#FFE600] text-black text-xs sm:text-sm font-bold tracking-[0.15em] uppercase px-5 py-2.5 rounded-full shadow-[0_4px_20px_rgba(255,230,0,0.3)] pointer-events-none">
          SESUDAH
        </div>

        <!-- Slider Handle -->
        <div class="absolute top-0 bottom-0 z-20" id="ba-handle" style="left: 50%;">
          <!-- Divider Line -->
          <div class="absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-[2px] bg-[#FFE600] shadow-[0_0_15px_rgba(255,230,0,0.5)]"></div>
          
          <!-- Handle Circle -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 sm:w-14 sm:h-14 bg-[#FFE600] rounded-full flex items-center justify-center shadow-[0_5px_20px_rgba(255,230,0,0.5)] cursor-grab active:cursor-grabbing hover:scale-110 transition-transform duration-200 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-8 sm:h-8 text-black group-active:scale-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 8L4 12L8 16M16 8L20 12L16 16M4 12H20" />
            </svg>
          </div>
        </div>

        <!-- Range Input (invisible overlay for interaction) -->
        <input
          type="range"
          min="0"
          max="100"
          value="50"
          class="absolute inset-0 w-full h-full opacity-0 cursor-grab active:cursor-grabbing z-30"
          id="ba-range"
          aria-label="Geser untuk membandingkan sebelum dan sesudah"
        />
      </div>
    </div>

  </div>
</section>

<script define:vars={{ categories }}>
  function initBeforeAfter() {
    const range = document.getElementById('ba-range');
    const beforeEl = document.getElementById('ba-before');
    const handle = document.getElementById('ba-handle');
    const tabs = document.querySelectorAll('.ba-tab');
    const imgBefore = document.getElementById('img-before');
    const imgAfter = document.getElementById('img-after');
    const loader = document.getElementById('ba-loader');

    if (!range || !beforeEl || !handle || !imgBefore || !imgAfter || !loader) return;

    // Reset Listeners (prevent duplicates on astro:page-load)
    const newRange = range.cloneNode(true);
    range.parentNode?.replaceChild(newRange, range);
    
    // Slider Logic
    newRange.addEventListener('input', (e) => {
      const val = e.target.value;
      beforeEl.style.clipPath = `inset(0 ${100 - val}% 0 0)`;
      handle.style.left = `${val}%`;
    });

    // Tab Logic
    tabs.forEach((tab) => {
      // Remove old listeners to prevent stacking
      const newTab = tab.cloneNode(true);
      tab.parentNode?.replaceChild(newTab, tab);
      
      newTab.addEventListener('click', () => {
        const index = newTab.getAttribute('data-index');
        const data = categories[index];

        // Update active class for all tabs
        document.querySelectorAll('.ba-tab').forEach(t => {
          t.classList.remove('bg-[#FFE600]', 'text-black', 'border-[#FFE600]');
          t.classList.add('bg-transparent', 'text-[#A1A1A1]', 'border-white/20');
        });
        newTab.classList.remove('bg-transparent', 'text-[#A1A1A1]', 'border-white/20');
        newTab.classList.add('bg-[#FFE600]', 'text-black', 'border-[#FFE600]');

        // Show Loader & Fade out images smoothly
        loader.style.opacity = '1';
        beforeEl.style.opacity = '0.3';
        imgAfter.style.opacity = '0.3';

        // Wait for fade out, then swap source
        setTimeout(() => {
          imgBefore.src = data.before;
          imgAfter.src = data.after;
          
          // Reset slider to center
          newRange.value = 50;
          beforeEl.style.clipPath = `inset(0 50% 0 0)`;
          handle.style.left = `50%`;

          // Wait a tiny bit for src to process, then fade back in
          setTimeout(() => {
            loader.style.opacity = '0';
            beforeEl.style.opacity = '1';
            imgAfter.style.opacity = '1';
          }, 150);
        }, 300);
      });
    });
  }

  // Initialize on regular load and Astro page transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBeforeAfter);
  } else {
    initBeforeAfter();
  }
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
