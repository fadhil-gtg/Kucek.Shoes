---
const steps = [
  {
    num: '01',
    title: 'KIRIM FOTO ITEM',
    desc: 'Kirim foto item melalui WhatsApp agar kami bisa mengecek kondisi dan kebutuhan treatment.',
  },
  {
    num: '02',
    title: 'DAPAT ESTIMASI HARGA',
    desc: 'Kami memberikan rekomendasi layanan dan estimasi biaya secara transparan sebelum pengerjaan.',
  },
  {
    num: '03',
    title: 'KAMI KERJAKAN',
    desc: 'Item ditangani dengan treatment yang sesuai menggunakan produk dan peralatan profesional.',
  },
  {
    num: '04',
    title: 'SIAP DIPAKAI LAGI',
    desc: 'Item kembali bersih, rapi, dan siap digunakan dengan percaya diri.',
  },
];

const waLink = 'https://wa.me/6281234567890?text=Halo%20kucek.shoes,%20saya%20ingin%20konsultasi';
---

<section id="cara-kerja" class="py-24 md:py-32 bg-[#0A0A0A]">
  <div class="container-main max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-left mb-16 md:mb-24">
      <span class="inline-block text-[#FFE600] font-bold text-sm tracking-[0.2em] uppercase mb-5">CARA KERJA</span>
      <h2 class="font-display text-white text-[3.5rem] sm:text-[5rem] lg:text-[7rem] leading-[0.9] uppercase tracking-wide mb-8">
        <span class="block">SEMUDAH INI</span>
        <span class="block text-white/70">MEMBUAT ITEMMU</span>
        <span class="block">KINCLONG LAGI</span>
      </h2>
      <p class="text-[#A1A1A1] text-lg md:text-xl max-w-2xl">
        Hanya 4 langkah sederhana untuk mengembalikan sepatu, tas, topi, dan aksesorismu ke kondisi terbaiknya.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative w-full mt-10 md:mt-20">
      <!-- Desktop Connecting Line -->
      <div class="hidden lg:block absolute top-[3rem] left-[12%] right-[12%] h-[1px] bg-gradient-to-r from-transparent via-[#FFE600]/30 to-transparent"></div>

      <!-- Mobile Connecting Line -->
      <div class="lg:hidden absolute top-8 bottom-8 left-10 w-[1px] bg-gradient-to-b from-transparent via-[#FFE600]/30 to-transparent"></div>

      <div class="flex flex-col lg:grid lg:grid-cols-4 gap-16 lg:gap-8">
        {steps.map((step, i) => (
          <div class="group relative flex lg:flex-col items-start lg:items-center text-left lg:text-center gap-8 lg:gap-0">
            <!-- Number -->
            <div class="relative z-10 shrink-0 w-20 text-center bg-[#0A0A0A] lg:w-auto lg:px-8 lg:mb-10 transition-transform duration-500 ease-out group-hover:scale-110">
              <span class="font-display text-[4.5rem] lg:text-[6rem] leading-none text-[#FFE600]/60 group-hover:text-[#FFE600] transition-colors duration-500">{step.num}</span>
            </div>

            <!-- Content -->
            <div class="flex flex-col justify-start pt-2 lg:pt-0">
              <h3 class="font-display text-2xl lg:text-3xl text-white uppercase tracking-wide mb-4 transition-transform duration-500 ease-out group-hover:-translate-y-[3px]">
                {step.title}
              </h3>
              <p class="text-[#A1A1A1] leading-relaxed text-base lg:text-lg">
                {step.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-20 md:mt-24">
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#FFE600] text-black font-bold uppercase tracking-widest text-sm md:text-base px-10 py-5 rounded-full hover:bg-white hover:scale-105 hover:shadow-[0_0_30px_rgba(255,230,0,0.3)] transition-all duration-300 ease-out">
        MULAI DARI WHATSAPP &rarr;
      </a>
    </div>
  </div>
</section>
