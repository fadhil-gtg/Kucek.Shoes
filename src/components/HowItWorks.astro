---
const steps = [
  {
    num: '01',
    title: 'Hubungi Kami',
    desc: 'Hubungi via WhatsApp untuk konsultasi awal dan tanyakan layanan yang kamu butuhkan.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>`,
  },
  {
    num: '02',
    title: 'Konsultasi',
    desc: 'Tim kami akan mengecek kondisi item dan merekomendasikan layanan yang paling sesuai.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
  },
  {
    num: '03',
    title: 'Proses Cleaning',
    desc: 'Item dikerjakan dengan teliti menggunakan peralatan dan produk cleaning terbaik.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>`,
  },
  {
    num: '04',
    title: 'Selesai & Dikirim',
    desc: 'Sepatu bersih dan rapi siap dikirim kembali. Kamu bisa cek hasilnya sebelum dikirim.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
  },
];

const waLink = 'https://wa.me/6281234567890?text=Halo%20kucek.shoes,%20saya%20ingin%20konsultasi';
---

<section id="cara-kerja" class="section-space bg-kucek-darker">
  <div class="container-main">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">Cara Kerja</span>
      <h2 class="heading-lg text-white mb-4">
        Proses yang Simpel dan Mudah
      </h2>
      <p class="text-body max-w-2xl mx-auto">
        Hanya 4 langkah mudah untuk membuat aksesorismu kembali bersih dan rapi.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute top-14 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-kucek-border to-transparent"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {steps.map((step, i) => (
          <div class={`reveal reveal-delay-${i + 1} text-center group`}>
            <!-- Number circle -->
            <div class="relative inline-flex items-center justify-center w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-kucek-dark border border-kucek-border mb-6 transition-all duration-300 group-hover:border-white/20 group-hover:bg-kucek-surface">
              <span class="text-2xl md:text-3xl font-extrabold text-white">{step.num}</span>
              <!-- Icon badge -->
              <div class="absolute -bottom-2 -right-2 w-8 h-8 rounded-lg bg-white flex items-center justify-center text-black">
                <Fragment set:html={step.icon} />
              </div>
            </div>

            <!-- Content -->
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-body-sm max-w-xs mx-auto">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-14 reveal">
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.913.913l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.326 0-4.48-.748-6.238-2.017l-.436-.327-2.687.9.916-2.719-.351-.457A9.953 9.953 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Mulai Konsultasi
      </a>
    </div>
  </div>
</section>
