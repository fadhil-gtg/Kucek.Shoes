---
const features = [
  {
    title: 'Deep Cleaning Detail',
    description: 'Membersihkan setiap sudut dan celah sepatu secara menyeluruh untuk hasil maksimal.',
    icon: `<svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`
  },
  {
    title: 'Aman untuk Semua Material',
    description: 'Aman untuk kulit, suede, canvas, mesh, dan berbagai jenis material lainnya.',
    icon: `<svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/></svg>`
  },
  {
    title: 'Hasil Bersih & Rapi',
    description: 'Item dikembalikan dalam kondisi bersih, rapi, dan terlihat lebih terawat.',
    icon: `<svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>`
  },
  {
    title: 'Cepat & Profesional',
    description: 'Pengerjaan efisien dengan standar kerja profesional dan teliti.',
    icon: `<svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>`
  }
];
---

<section id="why-choose-us" class="py-24 md:py-32 bg-[#0A0A0A]">
  <div class="container-main">
    <div class="max-w-6xl mx-auto">
      
      <!-- Header -->
      <div class="text-left mb-12 md:mb-16">
        <span class="inline-block text-[#FFE600] font-bold text-sm tracking-[0.2em] uppercase mb-5">KENAPA KUCEK.SHOES?</span>
        <h2 class="font-display text-white text-[4rem] sm:text-[5rem] lg:text-[7rem] leading-[0.9] uppercase tracking-wide">
          <span class="block">LEBIH DARI</span>
          <span class="block">SEKADAR <span class="text-[#FFE600]">BERSIH</span></span>
        </h2>
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl">
        {features.map((feature, index) => (
          <div 
            class="bg-[#111111] border border-white/5 rounded-[18px] p-8 lg:p-10 shadow-lg hover:-translate-y-2 hover:shadow-[0_15px_40px_-10px_rgba(255,230,0,0.15)] hover:border-[#FFE600]/20 transition-all duration-500 group"
          >
            <div class="w-14 h-14 rounded-full bg-white/5 flex items-center justify-center text-[#FFE600] mb-8 group-hover:scale-110 group-hover:bg-[#FFE600]/10 transition-transform duration-500" set:html={feature.icon}></div>
            <h3 class="text-2xl font-bold text-white mb-4">{feature.title}</h3>
            <p class="text-[#A1A1A1] text-lg leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
