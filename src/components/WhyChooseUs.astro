---
const reasons = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/></svg>`,
    title: 'Deep Cleaning Detail',
    desc: 'Setiap sudut dan celah sepatu dibersihkan secara menyeluruh dengan teknik pembersihan mendalam untuk hasil maksimal.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: 'Aman untuk Material',
    desc: 'Menggunakan produk pembersih khusus yang aman untuk semua jenis material — kulit, suede, canvas, mesh, dan lainnya.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
    title: 'Hasil Bersih dan Rapi',
    desc: 'Sepatu dikembalikan dalam kondisi terbaik — bersih, rapi, dan terlihat seperti baru lagi.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Proses Cepat dan Profesional',
    desc: 'Pengerjaan tepat waktu oleh tim berpengalaman. Cepat selesai tanpa mengorbankan kualitas.',
  },
];
---

<section id="kenapa-kami" class="section-space bg-kucek-black">
  <div class="container-main">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">Kenapa Kami</span>
      <h2 class="heading-lg text-white mb-4">
        Alasan Memilih kucek.shoes
      </h2>
      <p class="text-body max-w-2xl mx-auto">
        Kami berkomitmen memberikan layanan terbaik dengan standar tinggi
        untuk setiap item yang dipercayakan.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {reasons.map((reason, i) => (
        <div class={`reveal reveal-delay-${i + 1} card card-hover p-6 md:p-8 group`}>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-5 text-white transition-all duration-300 group-hover:bg-white/10 group-hover:border-white/20">
            <Fragment set:html={reason.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-lg font-bold text-white mb-3">{reason.title}</h3>
          <p class="text-body-sm">{reason.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
