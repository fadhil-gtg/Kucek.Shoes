---
const waLink = 'https://wa.me/6281234567890?text=Halo%20kucek.shoes,%20saya%20ingin%20order%20jasa%20cleaning';
---

<section id="cta-final" class="py-24 md:py-32 bg-[#0A0A0A]">
  <div class="container-main max-w-5xl mx-auto px-6">
    
    <!-- CTA Card -->
    <div class="relative bg-[#0B0B0B] border border-[#FFE600]/40 rounded-[24px] p-8 md:p-16 shadow-[0_0_40px_rgba(255,230,0,0.05)] hover:shadow-[0_0_50px_rgba(255,230,0,0.15)] hover:border-[#FFE600]/60 transition-all duration-500 overflow-hidden group">
      
      <!-- Subtle glow effect inside -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#FFE600]/5 to-transparent pointer-events-none transition-opacity duration-500 group-hover:opacity-100 opacity-70"></div>

      <div class="relative z-10 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-12 mb-16">
        
        <!-- Left Content -->
        <div class="max-w-2xl">
          <span class="inline-block text-[#FFE600] font-bold text-xs tracking-[0.2em] uppercase mb-6 px-3 py-1.5 rounded-full border border-[#FFE600]/20 bg-[#FFE600]/10">MULAI SEKARANG</span>
          <h2 class="font-display text-white text-[2.5rem] md:text-[3.5rem] lg:text-[4rem] leading-[1.1] uppercase tracking-wide mb-6">
            Siap Bikin Sepatu & Aksesorimu Kembali Bersih dan Rapi?
          </h2>
          <p class="text-[#A1A1A1] text-lg md:text-xl leading-relaxed">
            Percayakan pada KUCEK.SHOES dan rasakan hasil cleaning yang rapi, aman, dan profesional.
          </p>
        </div>

        <!-- Right Content (Button) -->
        <div class="shrink-0 w-full lg:w-auto">
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex w-full lg:w-auto items-center justify-center bg-[#FFE600] text-black font-bold uppercase tracking-widest text-sm md:text-base px-10 py-5 rounded-full hover:bg-white hover:scale-105 hover:shadow-[0_0_30px_rgba(255,230,0,0.3)] transition-all duration-300 ease-out text-center">
            Pesan Sekarang via WhatsApp
          </a>
        </div>
      </div>

      <!-- Bottom Trust Section -->
      <div class="relative z-10 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 pt-12 border-t border-white/10">
        <div class="flex flex-col">
          <span class="text-[#FFE600] font-display text-4xl md:text-5xl tracking-wide">100+</span>
          <span class="text-[#A1A1A1] text-xs uppercase tracking-widest font-bold mt-2">Pelanggan Puas</span>
        </div>
        <div class="flex flex-col">
          <span class="text-[#FFE600] font-display text-4xl md:text-5xl tracking-wide">500+</span>
          <span class="text-[#A1A1A1] text-xs uppercase tracking-widest font-bold mt-2">Item Dibersihkan</span>
        </div>
        <div class="flex flex-col">
          <span class="text-[#FFE600] font-display text-4xl md:text-5xl tracking-wide">5+</span>
          <span class="text-[#A1A1A1] text-xs uppercase tracking-widest font-bold mt-2">Tahun Pengalaman</span>
        </div>
      </div>

    </div>
  </div>
</section>
