---
const stats = [
  { value: '500', suffix: '+', label: 'Pelanggan Puas' },
  { value: '1000', suffix: '+', label: 'Item Dibersihkan' },
  { value: '4.9', suffix: '/5', label: 'Rating Pelanggan' },
  { value: '100', suffix: '%', label: 'Pengerjaan Teliti' },
];
---

<section id="trust" class="relative py-16 md:py-20 bg-kucek-darker border-y border-kucek-border/50">
  <div class="container-main">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat, i) => (
        <div class={`reveal reveal-delay-${i + 1} text-center group`}>
          <div class="relative p-6 md:p-8 rounded-2xl transition-all duration-300 hover:bg-kucek-surface/30">
            <!-- Number -->
            <div class="flex items-baseline justify-center gap-0.5 mb-2">
              <span
                class="stat-counter text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tabular-nums"
                data-target={stat.value}
              >
                0
              </span>
              <span class="text-xl sm:text-2xl md:text-3xl font-bold text-kucek-muted">
                {stat.suffix}
              </span>
            </div>
            <!-- Label -->
            <p class="text-sm sm:text-base text-kucek-gray font-medium">{stat.label}</p>

            <!-- Divider on desktop (except last) -->
            {i < stats.length - 1 && (
              <div class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 w-px h-12 bg-kucek-border"></div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const counters = entry.target.querySelectorAll('.stat-counter');
          counters.forEach((counter) => {
            const el = counter as HTMLElement;
            const target = el.dataset.target || '0';
            const isDecimal = target.includes('.');
            const targetNum = parseFloat(target);
            const duration = 2000;
            const startTime = performance.now();

            const animate = (currentTime: number) => {
              const elapsed = currentTime - startTime;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = targetNum * eased;

              el.textContent = isDecimal ? current.toFixed(1) : Math.floor(current).toString();

              if (progress < 1) {
                requestAnimationFrame(animate);
              } else {
                el.textContent = target;
              }
            };

            requestAnimationFrame(animate);
          });
          counterObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  const trustSection = document.getElementById('trust');
  if (trustSection) counterObserver.observe(trustSection);
</script>
