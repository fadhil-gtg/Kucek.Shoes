---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Layanan', href: '#layanan' },
  { label: 'Hasil Kerja', href: '#hasil' },
  { label: 'Harga', href: '#harga' },
  { label: 'Testimoni', href: '#testimoni' },
  { label: 'FAQ', href: '#faq' },
];

const serviceLinks = [
  'Deep Cleaning',
  'Regular Cleaning',
  'Whitening',
  'Repaint',
  'Unyellowing',
  'Protection Treatment',
];

const waLink = 'https://wa.me/6281234567890?text=Halo%20kucek.shoes';
---

<footer class="bg-kucek-darker border-t border-kucek-border">
  <div class="container-main py-16 md:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="#" class="inline-flex items-baseline gap-0.5 mb-4">
          <span class="text-xl font-extrabold text-white">kucek</span>
          <span class="text-xl font-extrabold text-kucek-muted">.shoes</span>
        </a>
        <p class="text-body-sm mb-6 max-w-xs">
          Jasa pembersih sepatu dan aksesoris profesional.
          Bersih, rapi, dan terpercaya.
        </p>
        <!-- Social -->
        <div class="flex items-center gap-3">
          <a href="https://instagram.com/kucek.shoes" target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-kucek-surface border border-kucek-border flex items-center justify-center text-kucek-muted hover:text-white hover:border-white/20 transition-all duration-300"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={waLink} target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-kucek-surface border border-kucek-border flex items-center justify-center text-kucek-muted hover:text-white hover:border-white/20 transition-all duration-300"
            aria-label="WhatsApp"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.913.913l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.326 0-4.48-.748-6.238-2.017l-.436-.327-2.687.9.916-2.719-.351-.457A9.953 9.953 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          </a>
          <a href="https://tiktok.com/@kucek.shoes" target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-kucek-surface border border-kucek-border flex items-center justify-center text-kucek-muted hover:text-white hover:border-white/20 transition-all duration-300"
            aria-label="TikTok"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13.1a8.24 8.24 0 005.58 2.19V11.8a4.83 4.83 0 01-4.83-.46V6.69h4.83z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Tautan Cepat</h4>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-kucek-gray hover:text-white transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Layanan</h4>
        <ul class="space-y-2.5">
          {serviceLinks.map((service) => (
            <li>
              <a href="#layanan" class="text-sm text-kucek-gray hover:text-white transition-colors duration-300">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Kontak</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-kucek-muted mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            <span class="text-sm text-kucek-gray">+62 812-3456-7890</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-kucek-muted mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            <span class="text-sm text-kucek-gray">hello@kucek.shoes</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-kucek-muted mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            <span class="text-sm text-kucek-gray">Jakarta, Indonesia</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-kucek-border">
    <div class="container-main py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-kucek-muted">
        &copy; {currentYear} kucek.shoes. Semua hak dilindungi.
      </p>
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="text-xs text-kucek-muted hover:text-white transition-colors duration-300">
        Hubungi Kami via WhatsApp
      </a>
    </div>
  </div>
</footer>
