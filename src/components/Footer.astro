---
const currentYear = new Date().getFullYear();
const waLink = 'https://wa.me/6281234567890?text=Halo%20kucek.shoes';
const igLink = 'https://instagram.com/kucek.shoes';
---

<footer class="bg-[#050505] border-t border-white/[0.08]">
  <div class="container-main max-w-6xl mx-auto px-6 py-20 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-12 lg:gap-24">
      
      <!-- Left: Brand -->
      <div class="flex flex-col">
        <a href="#" class="inline-block text-3xl font-extrabold text-white tracking-wider uppercase mb-6 font-display">
          KUCEK<span class="text-[#FFE600]">.SHOES</span>
        </a>
        <p class="text-[#A1A1A1] text-base leading-[1.8] mb-8 max-w-sm">
          Jasa pembersih sepatu dan aksesoris profesional dengan hasil rapi, aman, dan terpercaya.
        </p>
        <div class="flex items-center gap-5">
          <a href={igLink} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/40 hover:text-[#FFE600] transition-colors duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 7.5h.008M12 15a3 3 0 100-6 3 3 0 000 6zM6 6h12a3 3 0 013 3v12a3 3 0 01-3 3H6a3 3 0 01-3-3V9a3 3 0 013-3z"/></svg>
          </a>
          <a href={waLink} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="text-white/40 hover:text-[#FFE600] transition-colors duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          </a>
        </div>
      </div>

      <!-- Middle: Kontak -->
      <div class="flex flex-col">
        <h4 class="text-sm font-bold text-white uppercase tracking-[0.2em] mb-8">Hubungi Kami</h4>
        <ul class="space-y-6">
          <li class="flex flex-col gap-1.5">
            <span class="text-[11px] text-[#A1A1A1] uppercase tracking-widest font-bold">WhatsApp</span>
            <span class="text-white/90 text-base">+62 812 3456 7890</span>
          </li>
          <li class="flex flex-col gap-1.5">
            <span class="text-[11px] text-[#A1A1A1] uppercase tracking-widest font-bold">Instagram</span>
            <span class="text-white/90 text-base">@kucek.shoes</span>
          </li>
          <li class="flex flex-col gap-1.5">
            <span class="text-[11px] text-[#A1A1A1] uppercase tracking-widest font-bold">Jam Operasional</span>
            <span class="text-white/90 text-base leading-relaxed">Senin – Sabtu<br />08.00 – 20.00 WIB</span>
          </li>
          <li class="flex flex-col gap-1.5">
            <span class="text-[11px] text-[#A1A1A1] uppercase tracking-widest font-bold">Lokasi</span>
            <span class="text-white/90 text-base">Surabaya, Indonesia</span>
          </li>
        </ul>
      </div>

      <!-- Right: Trust -->
      <div class="flex flex-col">
        <h4 class="text-sm font-bold text-white uppercase tracking-[0.2em] mb-8">Dipercaya Pelanggan</h4>
        <div class="flex flex-col gap-8">
          <div class="flex flex-col">
            <span class="text-[#FFE600] font-display text-4xl tracking-wide">100+</span>
            <span class="text-[#A1A1A1] text-xs uppercase tracking-widest font-bold mt-2">Pelanggan Puas</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[#FFE600] font-display text-4xl tracking-wide">500+</span>
            <span class="text-[#A1A1A1] text-xs uppercase tracking-widest font-bold mt-2">Item Dibersihkan</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[#FFE600] font-display text-4xl tracking-wide">5+</span>
            <span class="text-[#A1A1A1] text-xs uppercase tracking-widest font-bold mt-2">Tahun Pengalaman</span>
          </div>
        </div>
      </div>
      
    </div>
  </div>

  <!-- Copyright & CTA bar -->
  <div class="border-t border-white/[0.05]">
    <div class="container-main max-w-6xl mx-auto px-6 py-6 md:py-8 flex flex-col sm:flex-row items-center justify-center sm:justify-between gap-6">
      <p class="text-[11px] md:text-xs text-[#A1A1A1] uppercase tracking-wider text-center sm:text-left">
        &copy; {currentYear} KUCEK.SHOES &bull; Dibuat untuk memberikan layanan cleaning terbaik.
      </p>
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-transparent border border-[#FFE600]/40 text-[#FFE600] font-bold uppercase tracking-widest text-[10px] md:text-xs px-5 py-2.5 rounded-full hover:bg-[#FFE600] hover:text-black transition-all duration-300">
        Pesan via WhatsApp
      </a>
    </div>
  </div>
</footer>
