---
const currentYear = new Date().getFullYear();
const waLink = 'https://wa.me/6282232725242?text=Halo%20kucek.shoes';
const igLink = 'https://instagram.com/kucek.shoes';
const tiktokLink = 'https://www.tiktok.com/@kucek.shoes';
const mapQuery = 'https://www.google.com/maps/search/?api=1&query=KUCEK.SHOES+MMV9%2BR2X,+Jl.+Raya+Lidah+Wetan,+Lidah+Wetan,+Kec.+Lakarsantri,+Surabaya,+Jawa+Timur+60213';
---

<footer class="bg-[#0A0A0A] border-t border-[#FFE600]/15">
  <div class="container-main max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
      
      <!-- Left: Brand -->
      <div class="flex flex-col">
        <a href="#" class="flex items-center gap-0 mb-6 group w-fit">
          <div class="font-display text-3xl md:text-4xl text-[#FFE600] tracking-wider italic flex flex-col items-start justify-center">
            <span class="leading-none">KUCEK.</span>
            <span class="leading-none -mt-2">SHOES</span>
          </div>
          <div class="w-12 h-12 md:w-16 md:h-16 -ml-2 bg-[#FFE600] opacity-90 group-hover:opacity-100 transition-opacity" style={`mask-image: url('${import.meta.env.BASE_URL}ikonkucek.png'); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url('${import.meta.env.BASE_URL}ikonkucek.png'); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}></div>
        </a>
        <p class="text-[#A1A1A1] text-sm md:text-base leading-[1.8] mb-8 max-w-sm">
          Jasa pembersih sepatu dan aksesoris profesional dengan hasil rapi, aman, dan terpercaya.
        </p>
        <div class="flex items-center gap-5">
          <!-- Instagram -->
          <a href={igLink} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-[#A1A1A1] hover:text-[#FFE600] hover:-translate-y-1 transition-all duration-300">
            <svg class="w-[22px] h-[22px] md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z" />
              <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M16.5 7.5l0 .01" />
            </svg>
          </a>
          <!-- TikTok -->
          <a href={tiktokLink} target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-[#A1A1A1] hover:text-[#FFE600] hover:-translate-y-1 transition-all duration-300">
            <svg class="w-[22px] h-[22px] md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M9 12a4 4 0 1 0 4 4v-12a5 5 0 0 0 5 5v2a7 7 0 0 1 -5 -2v7a6 6 0 1 1 -6 -6v2a4 4 0 1 0 4 4z" />
            </svg>
          </a>
          <!-- WhatsApp -->
          <a href={waLink} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="text-[#A1A1A1] hover:text-[#FFE600] hover:-translate-y-1 transition-all duration-300">
            <svg class="w-[22px] h-[22px] md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
              <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Middle: Kontak -->
      <div class="flex flex-col">
        <h4 class="text-xs font-bold text-[#FFE600] uppercase tracking-[0.2em] mb-8">Hubungi Kami</h4>
        <ul class="space-y-4">
          <li class="flex flex-col gap-1">
            <span class="text-[10px] text-[#A1A1A1] uppercase tracking-widest font-bold">WhatsApp</span>
            <a href={waLink} target="_blank" rel="noopener noreferrer" class="text-white/90 text-sm md:text-base hover:text-[#FFE600] hover:translate-x-1 transition-all duration-300 w-fit">
              +62 822-3272-5242
            </a>
          </li>
          <li class="flex flex-col gap-1">
            <span class="text-[10px] text-[#A1A1A1] uppercase tracking-widest font-bold">Instagram</span>
            <a href={igLink} target="_blank" rel="noopener noreferrer" class="text-white/90 text-sm md:text-base hover:text-[#FFE600] hover:translate-x-1 transition-all duration-300 w-fit">
              @kucek.shoes
            </a>
          </li>
          <li class="flex flex-col gap-1">
            <span class="text-[10px] text-[#A1A1A1] uppercase tracking-widest font-bold">TikTok</span>
            <a href={tiktokLink} target="_blank" rel="noopener noreferrer" class="text-white/90 text-sm md:text-base hover:text-[#FFE600] hover:translate-x-1 transition-all duration-300 w-fit">
              @kucek.shoes
            </a>
          </li>
        </ul>

        <div class="w-full h-[1px] bg-white/[0.08] my-6"></div>

        <ul class="space-y-4">
          <li class="flex flex-col gap-1">
            <span class="text-[10px] text-[#FFE600] uppercase tracking-widest font-bold mb-1">Jam Operasional</span>
            <span class="text-white/90 text-sm md:text-base leading-relaxed">
              Senin &ndash; Sabtu<br />10.00 &ndash; 21.00 WIB
            </span>
            <span class="text-white/90 text-sm md:text-base leading-relaxed mt-2">
              Minggu &amp; Tanggal Merah<br />15.00 &ndash; 21.00 WIB
            </span>
          </li>
        </ul>
      </div>

      <!-- Right: Lokasi Kami -->
      <div class="flex flex-col">
        <h4 class="text-xs font-bold text-[#FFE600] uppercase tracking-[0.2em] mb-8">Lokasi Kami</h4>
        
        <div class="w-full h-[180px] md:h-[220px] rounded-xl overflow-hidden border border-[#FFE600]/20 mb-5 relative group bg-[#111]">
          <!-- Placeholder map overlay -->
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3957.535805166299!2d112.6644265!3d-7.3048564!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7fc2580798e29%3A0xc3c544d6db8a1cc2!2sJl.%20Raya%20Lidah%20Wetan%2C%20Lidah%20Wetan%2C%20Kec.%20Lakarsantri%2C%20Surabaya%2C%20Jawa%20Timur!5e0!3m2!1sen!2sid!4v1680000000000!5m2!1sen!2sid" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="opacity-60 group-hover:opacity-100 transition-opacity duration-500 filter grayscale contrast-125 group-hover:grayscale-0">
          </iframe>
        </div>

        <div class="flex flex-col items-start gap-3 mt-1">
          <span class="text-white/80 text-sm leading-relaxed font-medium">
            Jl. Raya Lidah Wetan<br/>
            Lidah Wetan, Kec. Lakarsantri<br/>
            Surabaya, Jawa Timur
          </span>
          <a href={mapQuery} target="_blank" rel="noopener noreferrer" class="group/map text-[#FFE600] text-sm font-bold tracking-wide hover:text-white transition-colors duration-300 whitespace-nowrap flex items-center gap-1 mt-1">
            Lihat di Google Maps 
            <span class="transition-transform duration-300 group-hover/map:translate-x-1">&rarr;</span>
          </a>
        </div>
      </div>
      
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-white/[0.05]">
    <div class="container-main max-w-6xl mx-auto px-6 py-8">
      <p class="text-[10px] md:text-xs text-[#A1A1A1] uppercase tracking-wider text-center">
        &copy; {currentYear} <i>KUCEK.SHOES</i> &bull; Dibuat untuk memberikan layanan cleaning terbaik.
      </p>
    </div>
  </div>
</footer>
