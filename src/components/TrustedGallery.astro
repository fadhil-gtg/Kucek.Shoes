---
const galleryImages = [
  "/gambar-dipercaya/1.jpg", 
  "/gambar-dipercaya/2.jpg",  
  "/gambar-dipercaya/3.jpg",  
  "/gambar-dipercaya/4.jpg", 
  "/gambar-dipercaya/5.jpg" 
];
---

<section id="dipercaya-pelanggan" class="py-24 md:py-32 bg-[#0A0A0A] relative overflow-hidden">
  <div class="container-main max-w-7xl mx-auto px-6">
    
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-white uppercase tracking-wide leading-[1.1] mb-6">
        DIPERCAYA PELANGGAN SETIAP HARI
      </h2>
      <p class="text-[#A1A1A1] text-lg md:text-xl leading-relaxed">
        Setiap minggu puluhan pasang sepatu masuk ke workshop kami. Dari sneakers harian, running shoes, hingga sepatu premium, semuanya ditangani langsung oleh tim KUCEK.SHOES dengan proses yang aman dan teliti.
      </p>
    </div>

    <!-- Balanced Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-6">
      {galleryImages.map((img, idx) => {
        let heightClass = "h-[250px] md:h-[300px] lg:h-[350px]";
        let imageClass = "absolute inset-0 w-full h-full object-cover object-center";
        
        if (idx === 3) {
          heightClass = "h-full";
          imageClass = "absolute inset-0 w-full h-full object-cover object-bottom";
        } else if (idx === 4) {
          heightClass = "h-full";
          imageClass = "relative w-full h-auto block";
        }
        
        return (
          <div class={`group relative rounded-[20px] overflow-hidden border border-[#FFE600]/10 hover:border-[#FFE600]/50 transition-colors duration-500 bg-[#111] ${heightClass} ${idx < 3 ? 'md:col-span-2' : 'md:col-span-3'}`}>
            <div class="absolute inset-0 bg-black/40 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"></div>
            <img src={img} alt={`Kucek.Shoes activity ${idx + 1}`} class={`${imageClass} group-hover:scale-105 transition-transform duration-700 ease-out`} loading="lazy" />
          </div>
        );
      })}
    </div>

  </div>
</section>
