---
const services = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
    title: 'Deep Cleaning',
    desc: 'Pembersihan menyeluruh hingga ke sela-sela terkecil. Menghilangkan noda membandel dan mengembalikan tampilan asli sepatu.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z"/></svg>`,
    title: 'Regular Cleaning',
    desc: 'Perawatan rutin untuk menjaga kebersihan sepatu sehari-hari. Cocok untuk maintenance berkala.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>`,
    title: 'Whitening',
    desc: 'Proses pemutihan khusus untuk mengembalikan warna putih asli pada sole dan upper sepatu.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
    title: 'Repaint',
    desc: 'Pengecatan ulang sepatu untuk memperbaiki warna yang pudar atau mengubah tampilan dengan warna baru.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>`,
    title: 'Unyellowing',
    desc: 'Menghilangkan efek kuning pada sole midsole dan outsole. Tampilan kembali putih bersih seperti baru.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: 'Protection Treatment',
    desc: 'Lapisan pelindung untuk menjaga sepatu dari noda, air, dan kotoran. Perlindungan ekstra untuk aksesorismu.',
  },
];
---

<section id="layanan" class="section-space bg-kucek-black">
  <div class="container-main">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">Layanan Kami</span>
      <h2 class="heading-lg text-white mb-4">
        Apa yang Kami Kerjakan
      </h2>
      <p class="text-body max-w-2xl mx-auto">
        Berbagai layanan pembersihan dan perawatan profesional untuk menjaga aksesoris favoritmu tetap prima.
      </p>
    </div>

    <!-- Service Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {services.map((service, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} card card-hover p-6 md:p-8 group`}>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-5 text-white transition-all duration-300 group-hover:bg-white/10 group-hover:border-white/20">
            <Fragment set:html={service.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-lg font-bold text-white mb-3">{service.title}</h3>
          <p class="text-body-sm">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
