---
const services = [
  { 
    id: '01', 
    title: 'CUCI SEPATU', 
    desc: 'Pembersihan menyeluruh untuk sepatu harian hingga koleksi favorit agar kembali bersih, segar, dan nyaman digunakan.', 
    benefits: ['Deep Cleaning hingga sela terkecil', 'Aman untuk berbagai material sepatu', 'Hasil lebih bersih, segar, dan terawat'] 
  },
  { 
    id: '02', 
    title: 'REPAIR & RESTORASI', 
    desc: 'Mengembalikan tampilan dan fungsi sepatu yang rusak agar terlihat lebih rapi dan siap digunakan kembali.', 
    benefits: ['Repaint warna yang pudar atau terkelupas', 'Sewing untuk jahitan yang rusak', 'Unyellowing pada outsole menguning'] 
  },
  { 
    id: '03', 
    title: 'LEATHER CARE', 
    desc: 'Perawatan khusus material kulit untuk menjaga kebersihan, kelembapan, dan daya tahan item favoritmu.', 
    benefits: ['Aman untuk bahan kulit asli maupun sintetis', 'Membantu menjaga warna dan tekstur kulit', 'Mengurangi risiko kulit kering dan retak'] 
  },
  { 
    id: '04', 
    title: 'TAS & TOPI', 
    desc: 'Pembersihan dan perawatan tas serta topi dengan treatment yang disesuaikan berdasarkan materialnya.', 
    benefits: ['Aman untuk berbagai jenis bahan', 'Membersihkan noda dan debu membandel', 'Menjaga bentuk dan kualitas item'] 
  },
  { 
    id: '05', 
    title: 'HOME CARE', 
    desc: 'Layanan pembersihan sofa, kasur, dan karpet untuk membantu menjaga kebersihan serta kenyamanan rumah.', 
    benefits: ['Mengangkat debu dan kotoran tersembunyi', 'Membantu mengurangi bau tidak sedap', 'Dikerjakan dengan peralatan profesional'] 
  },
  { 
    id: '06', 
    title: 'PROTECTION', 
    desc: 'Lapisan perlindungan tambahan untuk membantu menjaga item tetap bersih lebih lama dari air, debu, dan noda ringan.', 
    benefits: ['Water & stain repellent', 'Membantu mengurangi penyerapan noda', 'Perlindungan ekstra untuk penggunaan harian'] 
  }
];
---

<section id="services" class="py-24 md:py-32 bg-[#0A0A0A]">
  <div class="container-main max-w-6xl mx-auto">
    
    <!-- Header -->
    <div class="text-left mb-16 md:mb-24">
      <span class="inline-block text-[#FFE600] font-bold text-sm tracking-[0.2em] uppercase mb-5">LAYANAN KAMI</span>
      <h2 class="font-display text-white text-[4rem] sm:text-[5rem] lg:text-[7rem] leading-[0.9] uppercase tracking-wide">
        <span class="block">APA YANG BISA</span>
        <span class="block text-white">KAMI TANGANI</span>
      </h2>
    </div>

    <!-- Desktop Split Layout -->
    <div class="hidden lg:grid grid-cols-12 gap-12 xl:gap-20 items-stretch">
      
      <!-- Left: Navigation Menu -->
      <div class="col-span-5 flex flex-col justify-center relative">
        <div class="absolute left-0 top-0 bottom-0 w-[1px] bg-white/10"></div>
        <div class="flex flex-col">
          {services.map((service, index) => (
            <button 
              class={`service-btn text-left py-6 px-8 transition-all duration-300 flex items-center gap-6 group relative ${index === 0 ? 'active' : ''}`}
              data-index={index}
            >
              <div class="active-indicator absolute left-[-1px] top-0 bottom-0 w-[2px] bg-[#FFE600] opacity-0 transition-opacity duration-300"></div>
              <span class="text-sm font-mono tracking-widest text-white/30 group-hover:text-[#FFE600] transition-colors duration-300 service-id">{service.id}</span>
              <span class="text-3xl xl:text-4xl font-display uppercase tracking-wider text-white/50 group-hover:text-[#FFE600] group-hover:translate-x-2 transition-all duration-300 service-title">{service.title}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Right: Detail Panel -->
      <div class="col-span-7 relative min-h-[480px]">
        <div class="bg-[#111111] border border-white/5 rounded-[20px] p-12 xl:p-16 shadow-2xl relative overflow-hidden h-full flex flex-col justify-center">
          
          <!-- Large Decorative Background Number -->
          <div id="panel-bg-num" class="absolute -right-4 -bottom-12 text-[20rem] xl:text-[24rem] leading-none font-display text-white/[0.03] select-none pointer-events-none transition-opacity duration-300">
            01
          </div>

          <!-- Content -->
          <div id="panel-content" class="relative z-10 transition-opacity duration-300">
            <h3 id="panel-title" class="text-4xl xl:text-5xl font-display text-white uppercase tracking-wide mb-6">Deep Cleaning</h3>
            <p id="panel-desc" class="text-[#A1A1A1] text-xl leading-relaxed mb-10 max-w-[90%]">
              Pembersihan menyeluruh hingga sela terkecil untuk hasil maksimal.
            </p>
            <ul id="panel-benefits" class="space-y-5">
              <li class="flex items-center gap-4 text-white/90 text-lg">
                <span class="text-[#FFE600] font-bold">✓</span>
                Membersihkan area sulit dijangkau
              </li>
              <li class="flex items-center gap-4 text-white/90 text-lg">
                <span class="text-[#FFE600] font-bold">✓</span>
                Aman untuk berbagai material
              </li>
              <li class="flex items-center gap-4 text-white/90 text-lg">
                <span class="text-[#FFE600] font-bold">✓</span>
                Hasil lebih bersih dan segar
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Stacked Card Layout -->
    <div class="lg:hidden flex flex-col gap-6 w-full mt-8">
      {services.map((service, index) => (
        <div class="mobile-service-card w-full transition-all duration-500 ease-out">
          <div class="card-inner bg-[#111111] border border-white/5 rounded-[24px] p-6 sm:p-8 shadow-lg overflow-hidden flex flex-col gap-5 transition-colors duration-500">
            <!-- Header Row: Number + Title -->
            <div class="flex items-center gap-4">
              <span class="card-num text-[3rem] font-display text-white/20 leading-none transition-colors duration-500">{service.id}</span>
              <h3 class="text-2xl sm:text-3xl font-display uppercase tracking-wide text-white mt-2 leading-none">{service.title}</h3>
            </div>
            <!-- Description -->
            <p class="text-[#A1A1A1] text-base sm:text-lg leading-relaxed">{service.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Active state for desktop buttons */
  .service-btn.active .service-id {
    color: #FFE600;
  }
  .service-btn.active .service-title {
    color: #FFE600;
    transform: translateX(0.5rem);
    opacity: 1;
  }
  .service-btn.active .active-indicator {
    opacity: 1;
  }
  .service-btn.active {
    background-color: rgba(255, 255, 255, 0.02);
  }

  /* Mobile Card Active State */
  .mobile-service-card {
    opacity: 0.4;
    transform: scale(0.95);
  }
  .mobile-service-card.active {
    opacity: 1;
    transform: scale(1);
  }
  .mobile-service-card.active .card-inner {
    border-color: rgba(255, 255, 255, 0.15);
    background-color: #161616;
  }
  .mobile-service-card.active .card-num {
    color: #FFE600;
  }
</style>

<script>
  const servicesData = [
    { id: '01', title: 'CUCI SEPATU', desc: 'Pembersihan menyeluruh untuk sepatu harian hingga koleksi favorit agar kembali bersih, segar, dan nyaman digunakan.', benefits: ['Deep Cleaning hingga sela terkecil', 'Aman untuk berbagai material sepatu', 'Hasil lebih bersih, segar, dan terawat'] },
    { id: '02', title: 'REPAIR & RESTORASI', desc: 'Mengembalikan tampilan dan fungsi sepatu yang rusak agar terlihat lebih rapi dan siap digunakan kembali.', benefits: ['Repaint warna yang pudar atau terkelupas', 'Sewing untuk jahitan yang rusak', 'Unyellowing pada outsole menguning'] },
    { id: '03', title: 'LEATHER CARE', desc: 'Perawatan khusus material kulit untuk menjaga kebersihan, kelembapan, dan daya tahan item favoritmu.', benefits: ['Aman untuk bahan kulit asli maupun sintetis', 'Membantu menjaga warna dan tekstur kulit', 'Mengurangi risiko kulit kering dan retak'] },
    { id: '04', title: 'TAS & TOPI', desc: 'Pembersihan dan perawatan tas serta topi dengan treatment yang disesuaikan berdasarkan materialnya.', benefits: ['Aman untuk berbagai jenis bahan', 'Membersihkan noda dan debu membandel', 'Menjaga bentuk dan kualitas item'] },
    { id: '05', title: 'HOME CARE', desc: 'Layanan pembersihan sofa, kasur, dan karpet untuk membantu menjaga kebersihan serta kenyamanan rumah.', benefits: ['Mengangkat debu dan kotoran tersembunyi', 'Membantu mengurangi bau tidak sedap', 'Dikerjakan dengan peralatan profesional'] },
    { id: '06', title: 'PROTECTION', desc: 'Lapisan perlindungan tambahan untuk membantu menjaga item tetap bersih lebih lama dari air, debu, dan noda ringan.', benefits: ['Water & stain repellent', 'Membantu mengurangi penyerapan noda', 'Perlindungan ekstra untuk penggunaan harian'] }
  ];

  function initServices() {
    // Desktop Interaction
    const btns = document.querySelectorAll('.service-btn');
    const panelBgNum = document.getElementById('panel-bg-num');
    const panelContent = document.getElementById('panel-content');
    const panelTitle = document.getElementById('panel-title');
    const panelDesc = document.getElementById('panel-desc');
    const panelBenefits = document.getElementById('panel-benefits');

    let isAnimating = false;

    btns.forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        if (btn.classList.contains('active') || isAnimating) return;
        
        const index = btn.getAttribute('data-index');
        const data = servicesData[index];
        
        // Remove active from all
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        isAnimating = true;

        // Fade out
        panelContent.style.opacity = '0';
        panelBgNum.style.opacity = '0';

        setTimeout(() => {
          // Update content
          panelBgNum.textContent = data.id;
          panelTitle.textContent = data.title;
          panelDesc.textContent = data.desc;
          
          panelBenefits.innerHTML = data.benefits.map(b => `
            <li class="flex items-center gap-4 text-white/90 text-lg">
              <span class="text-[#FFE600] font-bold">✓</span>
              ${b}
            </li>
          `).join('');

          // Fade in
          panelContent.style.opacity = '1';
          panelBgNum.style.opacity = '1';
          
          setTimeout(() => {
            isAnimating = false;
          }, 300); // match transition duration
        }, 150);
      });
    });

    // Mobile Interaction (Scroll Spy)
    const mobileCards = document.querySelectorAll('.mobile-service-card');
    if (mobileCards.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          } else {
            entry.target.classList.remove('active');
          }
        });
      }, {
        rootMargin: '-35% 0px -35% 0px',
        threshold: 0
      });

      mobileCards.forEach(card => observer.observe(card));
    }
  }

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServices);
  } else {
    initServices();
  }
</script>
