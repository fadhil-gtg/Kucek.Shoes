---
const services = [
  { 
    id: '01', 
    title: 'Deep Cleaning', 
    desc: 'Pembersihan menyeluruh hingga sela terkecil untuk hasil maksimal.', 
    benefits: ['Membersihkan area sulit dijangkau', 'Aman untuk berbagai material', 'Hasil lebih bersih dan segar'] 
  },
  { 
    id: '02', 
    title: 'Regular Cleaning', 
    desc: 'Pembersihan standar untuk perawatan harian sepatu kesayanganmu.', 
    benefits: ['Cepat dan efisien', 'Menjaga keawetan sepatu', 'Cocok untuk kotoran ringan'] 
  },
  { 
    id: '03', 
    title: 'Whitening', 
    desc: 'Mengembalikan warna putih cerah pada sol sepatu yang menguning.', 
    benefits: ['Menghilangkan noda kuning', 'Formula khusus anti-rusak', 'Sepatu terlihat seperti baru'] 
  },
  { 
    id: '04', 
    title: 'Repaint', 
    desc: 'Pengecatan ulang untuk mengembalikan warna asli atau kustom warna baru.', 
    benefits: ['Warna tajam dan awet', 'Bahan cat premium', 'Pengerjaan sangat detail'] 
  },
  { 
    id: '05', 
    title: 'Unyellowing', 
    desc: 'Perawatan intensif khusus untuk material karet dan plastik yang menguning.', 
    benefits: ['Teknik oksidasi khusus', 'Material kembali putih', 'Mencegah kerusakan lanjut'] 
  },
  { 
    id: '06', 
    title: 'Protection', 
    desc: 'Lapisan pelindung anti air dan noda untuk melindungi sepatu barumu.', 
    benefits: ['Water & stain repellent', 'Efek daun talas', 'Perlindungan hingga 3 bulan'] 
  }
];
---

<section id="services" class="py-24 md:py-32 bg-[#0A0A0A]">
  <div class="container-main max-w-6xl mx-auto">
    
    <!-- Header -->
    <div class="text-left mb-16 md:mb-24">
      <span class="inline-block text-[#FFE600] font-bold text-sm tracking-[0.2em] uppercase mb-5">LAYANAN KAMI</span>
      <h2 class="font-display text-white text-[4rem] sm:text-[5rem] lg:text-[7rem] leading-[0.9] uppercase tracking-wide">
        <span class="block">APA YANG KAMI</span>
        <span class="block text-white">KERJAKAN</span>
      </h2>
    </div>

    <!-- Desktop Split Layout -->
    <div class="hidden lg:grid grid-cols-12 gap-12 xl:gap-20 items-stretch">
      
      <!-- Left: Navigation Menu -->
      <div class="col-span-5 flex flex-col justify-center relative">
        <div class="absolute left-0 top-0 bottom-0 w-[1px] bg-white/10"></div>
        <div class="flex flex-col">
          {services.map((service, index) => (
            <button 
              class={`service-btn text-left py-6 px-8 transition-all duration-300 flex items-center gap-6 group relative ${index === 0 ? 'active' : ''}`}
              data-index={index}
            >
              <div class="active-indicator absolute left-[-1px] top-0 bottom-0 w-[2px] bg-[#FFE600] opacity-0 transition-opacity duration-300"></div>
              <span class="text-sm font-mono tracking-widest text-white/30 group-hover:text-[#FFE600] transition-colors duration-300 service-id">{service.id}</span>
              <span class="text-3xl xl:text-4xl font-display uppercase tracking-wider text-white/50 group-hover:text-[#FFE600] group-hover:translate-x-2 transition-all duration-300 service-title">{service.title}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Right: Detail Panel -->
      <div class="col-span-7 relative min-h-[480px]">
        <div class="bg-[#111111] border border-white/5 rounded-[20px] p-12 xl:p-16 shadow-2xl relative overflow-hidden h-full flex flex-col justify-center">
          
          <!-- Large Decorative Background Number -->
          <div id="panel-bg-num" class="absolute -right-4 -bottom-12 text-[20rem] xl:text-[24rem] leading-none font-display text-white/[0.03] select-none pointer-events-none transition-opacity duration-300">
            01
          </div>

          <!-- Content -->
          <div id="panel-content" class="relative z-10 transition-opacity duration-300">
            <h3 id="panel-title" class="text-4xl xl:text-5xl font-display text-white uppercase tracking-wide mb-6">Deep Cleaning</h3>
            <p id="panel-desc" class="text-[#A1A1A1] text-xl leading-relaxed mb-10 max-w-[90%]">
              Pembersihan menyeluruh hingga sela terkecil untuk hasil maksimal.
            </p>
            <ul id="panel-benefits" class="space-y-5">
              <li class="flex items-center gap-4 text-white/90 text-lg">
                <span class="text-[#FFE600] font-bold">✓</span>
                Membersihkan area sulit dijangkau
              </li>
              <li class="flex items-center gap-4 text-white/90 text-lg">
                <span class="text-[#FFE600] font-bold">✓</span>
                Aman untuk berbagai material
              </li>
              <li class="flex items-center gap-4 text-white/90 text-lg">
                <span class="text-[#FFE600] font-bold">✓</span>
                Hasil lebih bersih dan segar
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Stacked Card Layout -->
    <div class="lg:hidden relative w-full mt-8" style="height: 240vh;">
      {services.map((service, index) => (
        <div 
          class="absolute w-full"
          style={`top: ${index * 32}vh; bottom: ${(services.length - 1 - index) * 15}vh; z-index: ${index + 10};`}
        >
          <div 
            class="sticky w-full transition-transform"
            style={`top: ${90 + (index * 75)}px;`}
          >
            <div class="bg-[#111111] border border-white/10 rounded-[24px] p-6 sm:p-8 shadow-[0_-15px_40px_rgba(0,0,0,0.8)] relative overflow-hidden flex flex-col gap-5">
              <!-- Header Row: Number + Title -->
              <div class="flex items-center gap-4">
                <span class="text-[3rem] font-display text-[#FFE600] leading-none">{service.id}</span>
                <h3 class="text-2xl sm:text-3xl font-display uppercase tracking-wide text-white mt-2 leading-none">{service.title}</h3>
              </div>
              <!-- Description -->
              <p class="text-[#A1A1A1] text-base sm:text-lg leading-relaxed">{service.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Active state for desktop buttons */
  .service-btn.active .service-id {
    color: #FFE600;
  }
  .service-btn.active .service-title {
    color: #FFE600;
    transform: translateX(0.5rem);
    opacity: 1;
  }
  .service-btn.active .active-indicator {
    opacity: 1;
  }
  .service-btn.active {
    background-color: rgba(255, 255, 255, 0.02);
  }
</style>

<script>
  const servicesData = [
    { id: '01', title: 'Deep Cleaning', desc: 'Pembersihan menyeluruh hingga sela terkecil untuk hasil maksimal.', benefits: ['Membersihkan area sulit dijangkau', 'Aman untuk berbagai material', 'Hasil lebih bersih dan segar'] },
    { id: '02', title: 'Regular Cleaning', desc: 'Pembersihan standar untuk perawatan harian sepatu kesayanganmu.', benefits: ['Cepat dan efisien', 'Menjaga keawetan sepatu', 'Cocok untuk kotoran ringan'] },
    { id: '03', title: 'Whitening', desc: 'Mengembalikan warna putih cerah pada sol sepatu yang menguning.', benefits: ['Menghilangkan noda kuning', 'Formula khusus anti-rusak', 'Sepatu terlihat seperti baru'] },
    { id: '04', title: 'Repaint', desc: 'Pengecatan ulang untuk mengembalikan warna asli atau kustom warna baru.', benefits: ['Warna tajam dan awet', 'Bahan cat premium', 'Pengerjaan sangat detail'] },
    { id: '05', title: 'Unyellowing', desc: 'Perawatan intensif khusus untuk material karet dan plastik yang menguning.', benefits: ['Teknik oksidasi khusus', 'Material kembali putih', 'Mencegah kerusakan lanjut'] },
    { id: '06', title: 'Protection', desc: 'Lapisan pelindung anti air dan noda untuk melindungi sepatu barumu.', benefits: ['Water & stain repellent', 'Efek daun talas', 'Perlindungan hingga 3 bulan'] }
  ];

  function initServices() {
    // Desktop Interaction
    const btns = document.querySelectorAll('.service-btn');
    const panelBgNum = document.getElementById('panel-bg-num');
    const panelContent = document.getElementById('panel-content');
    const panelTitle = document.getElementById('panel-title');
    const panelDesc = document.getElementById('panel-desc');
    const panelBenefits = document.getElementById('panel-benefits');

    let isAnimating = false;

    btns.forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        if (btn.classList.contains('active') || isAnimating) return;
        
        const index = btn.getAttribute('data-index');
        const data = servicesData[index];
        
        // Remove active from all
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        isAnimating = true;

        // Fade out
        panelContent.style.opacity = '0';
        panelBgNum.style.opacity = '0';

        setTimeout(() => {
          // Update content
          panelBgNum.textContent = data.id;
          panelTitle.textContent = data.title;
          panelDesc.textContent = data.desc;
          
          panelBenefits.innerHTML = data.benefits.map(b => `
            <li class="flex items-center gap-4 text-white/90 text-lg">
              <span class="text-[#FFE600] font-bold">✓</span>
              ${b}
            </li>
          `).join('');

          // Fade in
          panelContent.style.opacity = '1';
          panelBgNum.style.opacity = '1';
          
          setTimeout(() => {
            isAnimating = false;
          }, 300); // match transition duration
        }, 150);
      });
    });

  }

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServices);
  } else {
    initServices();
  }
</script>
