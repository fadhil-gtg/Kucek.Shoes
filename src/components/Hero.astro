---
import { getImage } from "astro:assets";
import bgWorker from "../assets/bg-worker.jpg";

const waLink = 'https://wa.me/6282232725242?text=Halo%20kucek.shoes,%20saya%20ingin%20order%20jasa%20cleaning';

const optimizedBg = await getImage({ src: bgWorker, format: 'webp' });
---

<section id="hero" class="relative min-h-screen flex items-center pt-16 pb-12 md:pt-0 md:pb-0 overflow-hidden bg-[#0A0A0A] bg-cover bg-[60%_80%] md:bg-center" style={`background-image: url('${optimizedBg.src}');`}>
  <!-- Dark overlay for text readability, strong vignette, left-to-right fade -->
  <div class="absolute inset-0 z-0 bg-black/5 md:bg-black/20"></div>
  <div class="absolute inset-0 z-0 bg-gradient-to-r from-[#0A0A0A]/95 via-[#0A0A0A]/70 to-transparent md:from-[#0A0A0A] md:via-[#0A0A0A]/95 md:to-transparent w-full md:w-3/4"></div>
  <div class="absolute inset-0 z-0 bg-gradient-to-t from-[#0A0A0A] via-transparent to-black/20 md:to-black/50"></div>
  <div class="absolute inset-0 z-0 shadow-[inset_0_0_80px_rgba(0,0,0,0.5)] md:shadow-[inset_0_0_150px_rgba(0,0,0,0.9)]"></div> <!-- Vignette -->

  <div class="container-main relative z-10 w-full flex items-center px-8 sm:px-6 lg:px-8">
    <div class="w-full lg:w-[60%] xl:w-[55%] text-left pt-2 pb-8 md:pt-10 lg:py-0">

      <!-- Headline -->
      <h1 class="font-display tracking-wide uppercase flex flex-col text-left text-[5.5rem] sm:text-[7.5rem] lg:text-[8.5rem] xl:text-[10rem] leading-[0.85] mb-10 animate-slide-up" style="animation-delay: 2.2s;">
        <span class="text-white block">BIKIN</span>
        <span class="text-[#4A4A4A] block -mt-2 sm:-mt-4 lg:-mt-5">KOTOR</span>
        <span class="text-white block -mt-2 sm:-mt-4 lg:-mt-5">
          JADI <span class="text-[#FFE600]">BERSIH</span>
        </span>
      </h1>

      <!-- Description -->
      <p class="text-body text-white/80 max-w-[520px] mb-8 md:mb-12 animate-slide-up text-lg md:text-xl font-medium leading-relaxed" style="animation-delay: 2.4s;">
        Cleaning profesional untuk sepatu, tas, topi, dan aksesoris.
      </p>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 sm:gap-5 lg:gap-6 justify-start animate-slide-up" style="animation-delay: 2.5s;">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 bg-[#FFE600] text-black font-bold h-14 sm:h-[60px] px-8 sm:px-10 rounded-full hover:-translate-y-1 hover:shadow-xl hover:shadow-[#FFE600]/25 transition-all duration-300 text-base sm:text-lg">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.52 3.48A11.86 11.86 0 0 0 12.08 0C5.5 0 .15 5.35.15 11.93c0 2.1.55 4.16 1.6 5.97L0 24l6.25-1.64a11.9 11.9 0 0 0 5.83 1.49h.01c6.58 0 11.93-5.35 11.93-11.93 0-3.18-1.24-6.18-3.5-8.44ZM12.09 21.84h-.01a9.9 9.9 0 0 1-5.05-1.38l-.36-.21-3.71.97.99-3.62-.23-.37a9.87 9.87 0 0 1-1.51-5.3c0-5.47 4.45-9.92 9.93-9.92 2.65 0 5.14 1.03 7.01 2.91a9.86 9.86 0 0 1 2.91 7.01c0 5.47-4.45 9.91-9.92 9.91Zm5.44-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.88 1.21 3.07c.15.2 2.09 3.2 5.07 4.49.71.31 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.69.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35Z"/></svg>
          Pesan Sekarang
        </a>
        <a href="#hasil" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white/20 text-white font-medium h-14 sm:h-[60px] px-8 sm:px-10 rounded-full hover:bg-white/10 hover:border-white/40 transition-all duration-300 text-base sm:text-lg">
          Lihat Hasil Kerja
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float hidden md:block">
    <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center pt-2">
      <div class="w-1 h-2.5 bg-white/40 rounded-full animate-pulse"></div>
    </div>
  </div>
</section>
