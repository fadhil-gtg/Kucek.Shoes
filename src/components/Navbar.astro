---
const navLinks = [
  { label: 'Layanan', href: '#services' },
  { label: 'Hasil Kerja', href: '#hasil' },
  { label: 'Harga', href: '#harga' },
  { label: 'Testimoni', href: '#testimoni' },
  { label: 'FAQ', href: '#faq' },
];

const waLink = 'https://wa.me/6282232725242?text=Halo%20kucek.shoes,%20saya%20ingin%20order%20jasa%20cleaning';
---

<header id="navbar" class="fixed top-4 left-4 right-4 lg:left-1/2 lg:-translate-x-1/2 lg:w-[calc(100%-2rem)] max-w-6xl z-50 transition-all duration-500 bg-[#FFF200]/90 backdrop-blur-md rounded-full shadow-none px-6 md:px-8 nav-animate-container">
  <div class="w-full">
    <nav id="nav-container" class="flex items-center justify-between h-16 md:h-20 relative transition-all duration-500">
      <!-- Logo -->
      <a href="#" class="relative z-10 flex items-center gap-0 group nav-animate-logo">
        <div class="logo-text font-display text-2xl md:text-3xl text-black tracking-wider italic flex flex-col items-start justify-center transition-all duration-500">
          <span class="leading-none">KUCEK.</span>
          <span class="leading-none -mt-2">SHOES</span>
        </div>
        <img src={`${import.meta.env.BASE_URL}ikonkucek.png`} alt="kucek.shoes logo" class="logo-img w-11 h-11 md:w-14 md:h-14 object-contain -ml-2 md:-ml-4 transition-all duration-500" />
      </a>

      <!-- Desktop Nav Links (Centered) -->
      <div class="hidden lg:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
        {navLinks.map((link, index) => (
          <a href={link.href} class="nav-animate-item relative whitespace-nowrap text-base text-black/70 hover:text-black transition-colors duration-300 font-bold group" style={`animation-delay: ${200 + index * 40}ms;`}>
            {link.label}
            <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-black transition-all duration-300 ease-out group-hover:w-full"></span>
          </a>
        ))}
      </div>

      <!-- Right Side Actions -->
      <div class="flex items-center relative z-10 nav-animate-action">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="hidden lg:flex btn-primary !bg-black !text-[#FFF200] !py-2.5 !px-6 !rounded-full !text-base hover:!scale-105 transition-transform">
          Order Sekarang
        </a>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-toggle"
          class="relative z-50 lg:hidden flex flex-col items-end justify-center w-10 h-10 gap-[6px] group cursor-pointer ml-4"
          aria-label="Toggle menu"
        >
          <span class="hamburger-line w-5 h-[3px] bg-black transition-all duration-300 rounded-full"></span>
          <span class="hamburger-line w-8 h-[3px] bg-black transition-all duration-300 rounded-full"></span>
          <span class="hamburger-line w-6 h-[3px] bg-black transition-all duration-300 rounded-full"></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Full Screen Mobile Menu Overlay -->
<div id="mobile-menu" class="lg:hidden fixed inset-0 bg-[#0A0A0A]/95 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500 ease-in-out z-[100] flex flex-col items-center justify-center px-6">
  
  <!-- Close Button -->
  <button id="mobile-close" class="absolute top-6 right-6 w-12 h-12 flex items-center justify-center text-white/80 hover:text-[#FFE600] transition-colors" aria-label="Close menu">
    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>

  <div class="flex flex-col items-center justify-center w-full gap-8">
    {navLinks.map((link, index) => (
      <a href={link.href} class="mobile-link text-4xl font-display tracking-wider text-white/90 hover:text-[#FFE600] opacity-0 translate-y-8" style={`--i: ${index};`}>
        {link.label}
      </a>
    ))}
    <a href={waLink} target="_blank" rel="noopener noreferrer" class="mobile-link !bg-[#FFE600] !text-black py-4 px-10 rounded-full text-xl font-bold tracking-wide mt-4 opacity-0 translate-y-8 hover:scale-105 shadow-lg shadow-[#FFE600]/20" style={`--i: ${navLinks.length};`}>
      ORDER SEKARANG
    </a>
  </div>
</div>

<style>
  /* Entrance Animations */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes navEntranceMobile {
      0% { opacity: 0; transform: translateY(-20px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    @keyframes navEntranceDesktop {
      0% { opacity: 0; transform: translate(-50%, -20px); }
      100% { opacity: 1; transform: translate(-50%, 0); }
    }
    @keyframes navItemFadeUp {
      0% { opacity: 0; transform: translateY(10px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .nav-animate-container {
      animation: navEntranceMobile 400ms ease-out backwards;
    }
    @media (min-width: 1024px) {
      .nav-animate-container {
        animation: navEntranceDesktop 400ms ease-out backwards;
      }
    }

    .nav-animate-logo {
      animation: navItemFadeUp 300ms ease-out 150ms backwards;
    }

    .nav-animate-item {
      animation-name: navItemFadeUp;
      animation-duration: 300ms;
      animation-timing-function: ease-out;
      animation-fill-mode: backwards;
    }

    .nav-animate-action {
      animation: navItemFadeUp 300ms ease-out 350ms backwards;
    }
  }

  /* Scrolled state */
  #navbar.scrolled {
    @apply bg-[#FFF200] shadow-md max-w-[58rem];
  }
  
  #navbar.scrolled #nav-container {
    @apply h-14 md:h-16;
  }

  #navbar.scrolled .logo-text {
    @apply text-xl md:text-2xl;
  }

  #navbar.scrolled .logo-img {
    @apply w-9 h-9 md:w-11 md:h-11;
  }

  /* Hamburger lines */
  .hamburger-line {
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hamburger hover */
  #mobile-toggle:hover .hamburger-line {
    @apply w-8;
  }

  /* Hamburger open state */
  #mobile-toggle.open .hamburger-line {
    @apply w-8;
  }
  #mobile-toggle.open .hamburger-line:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  #mobile-toggle.open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #mobile-toggle.open .hamburger-line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* Mobile menu open */
  #mobile-menu.open {
    @apply opacity-100 pointer-events-auto;
  }

  #mobile-menu.open .mobile-link {
    @apply opacity-100 translate-y-0;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: calc(100ms * var(--i) + 150ms);
  }

  #mobile-menu:not(.open) .mobile-link {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  // Scroll detection
  const navbar = document.getElementById('navbar');
  const onScroll = () => {
    if (window.scrollY > 30) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  const toggle = document.getElementById('mobile-toggle');
  const closeBtn = document.getElementById('mobile-close');
  const mobileMenu = document.getElementById('mobile-menu');

  const openMenu = () => {
    toggle?.classList.add('open');
    mobileMenu?.classList.add('open');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    toggle?.classList.remove('open');
    mobileMenu?.classList.remove('open');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
