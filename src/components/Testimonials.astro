---
const testimonials = [
  {
    name: 'Fajri Alfath',
    location: 'Google Review',
    rating: 5,
    text: 'Layanan bagus dan pelayanannya sangat ramah sekali. Sepatu awalnya kotor parah jadi sangat bersih. Pokoknya josjis!',
    link: 'https://share.google/m844onYmdDFT1Wiad'
  },
  {
    name: 'Wawan Hendriawan',
    location: 'Google Review',
    rating: 5,
    text: 'Pengerjaan bagus, rapi dan sesuai dengan harapan. Untuk harga sendiri ramah di kantong. Ga bakal kapok nyuci sepatu di sini. Ownernya juga ramah. Maju terus <i>KUCEK.SHOES</i>! 🤙',
    link: 'https://share.google/foKLgMZTNAARHJFDv'
  },
  {
    name: 'Dea Natalia',
    location: 'Google Review',
    rating: 5,
    text: 'Kesekian kalinya cuci disini, bersih wangi selalu terpercaya. Rekomendasi banget, murah pastinya! Pertahankan service-nya ✨',
    link: 'https://share.google/RoORExgNk7Ds83ifw'
  },
  {
    name: 'Riky Jefri',
    location: 'Google Review',
    rating: 5,
    text: 'Mas-nya ramah dan benar sepatu kotor ga berharap jadi baru. Tapi menurutku bersih dan murah 🤘',
    link: 'https://share.google/rd2hyRXflkhVCQO2W'
  },
  {
    name: 'Riza Salma',
    location: 'Google Review',
    rating: 5,
    text: 'Pengerjaan bagus, sepatu kotor parah setelah di laundry jadi bersih dan wangi. Pelayanan baik dan ramah serta harganya terjangkau.',
    link: 'https://share.google/YafgrxqwLru0OBfb1'
  },
];
---

<section id="testimoni" class="py-24 md:py-32 bg-[#0A0A0A]">
  <div class="container-main max-w-6xl mx-auto px-6">
    
    <!-- Top Content: Header, Stats, Button -->
    <div class="flex flex-col lg:flex-row justify-between items-start gap-12 lg:gap-16 mb-20">
      
      <!-- Left: Header -->
      <div class="text-left max-w-2xl">
        <span class="inline-block text-[#FFD600] font-bold text-sm tracking-[0.2em] uppercase mb-5">TESTIMONI</span>
        <h2 class="font-display text-white text-[3rem] sm:text-[4.5rem] lg:text-[5.5rem] leading-[0.9] uppercase tracking-wide mb-6">
          Apa Kata<br />Pelanggan Kami
        </h2>
        <p class="text-[#A1A1A1] text-lg">
          Dipercaya ratusan pelanggan untuk perawatan sepatu, tas, topi, dan leather care dengan hasil yang rapi dan konsisten.
        </p>
      </div>

      <!-- Right: Stats & Button -->
      <div class="flex flex-col w-full lg:w-auto">


        <!-- Google Review CTA -->
        <div>
          <a href="https://www.google.com/search?q=kucek+shoes&oq=ku&gs_lcrp=EgZjaHJvbWUqDggBEEUYJxg7GIAEGIoFMgYIABBFGDwyDggBEEUYJxg7GIAEGIoFMhIIAhAuGEMYxwEY0QMYgAQYigUyCAgDEEUYJxg7MgYIBBBFGDkyBggFEEUYPDIGCAYQRRg9MgYIBxBFGD3SAQgyMDA2ajBqN6gCALACAA&sourceid=chrome&ie=UTF-8#lrd=0x2dd7fd0026b4af11:0xcce9dca694115e88,1,,,," target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 border border-[#FFD600] text-[#FFD600] font-bold uppercase tracking-widest text-sm px-8 py-4 rounded-full hover:bg-[#FFD600] hover:text-black transition-all duration-300 w-full sm:w-auto">
            ⭐ Lihat Review Google
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Content: Swiper (Full Width) -->
    <div class="w-full overflow-hidden">
      <div class="swiper testimonial-swiper h-full">
        <div class="swiper-wrapper pb-16">
          {testimonials.map((t) => (
            <div class="swiper-slide h-auto">
              <a href={t.link} target="_blank" rel="noopener noreferrer" class="bg-[#111111] border border-white/5 p-8 md:p-10 rounded-[24px] h-full flex flex-col hover:border-white/20 transition-all duration-300 group">
                <!-- Stars -->
                <div class="flex items-center gap-1 mb-6">
                  {Array.from({ length: t.rating }).map(() => (
                    <svg class="w-5 h-5 text-[#FFD600]" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>

                <!-- Quote -->
                <p class="text-white/90 text-lg md:text-xl leading-relaxed mb-8 flex-grow" set:html={`"${t.text}"`}>
                </p>

                <!-- Author -->
                <div class="mt-auto pt-6 border-t border-white/5 flex items-center justify-between">
                  <div>
                    <p class="text-white font-bold text-lg group-hover:text-[#FFD600] transition-colors">{t.name}</p>
                    {t.location && <p class="text-[#A1A1A1] text-sm mt-1">{t.location}</p>}
                  </div>
                  <svg class="w-5 h-5 text-white/30 group-hover:text-[#FFD600] transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </div>
              </a>
            </div>
          ))}
        </div>

        <!-- Pagination -->
        <div class="swiper-pagination !relative !bottom-0 mt-4"></div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Custom Swiper Pagination Styles to match the dark theme */
  :global(.testimonial-swiper .swiper-pagination-bullet) {
    background: rgba(255, 255, 255, 0.2);
    opacity: 1;
  }
  :global(.testimonial-swiper .swiper-pagination-bullet-active) {
    background: #FFD600;
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';

  new Swiper('.testimonial-swiper', {
    modules: [Pagination, Autoplay],
    slidesPerView: 1,
    spaceBetween: 20,
    loop: true,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      768: {
        slidesPerView: 2,
        spaceBetween: 24,
      },
    },
  });
</script>
